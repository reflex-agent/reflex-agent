# Always include only what `files` whitelists in package.json — but inside
# those entries, drop noise we don't want to ship.

# Next build cache (huge, machine-specific, not needed at runtime).
.next/cache
.next/cache/**

# TypeScript build info (machine-specific).
**/*.tsbuildinfo

# Source maps for the CLI (debug-only, bloat).
dist/**/*.js.map

# Editor / OS noise.
.DS_Store
.vscode/
.idea/
