{
  "name": "reflex-agent",
  "version": "0.3.0",
  "private": false,
  "description": "Local-first knowledge base built by an agent over a chosen directory.",
  "license": "MIT",
  "author": "legostin",
  "homepage": "https://github.com/legostin/reflex-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legostin/reflex-agent.git"
  },
  "bugs": {
    "url": "https://github.com/legostin/reflex-agent/issues"
  },
  "type": "module",
  "bin": {
    "reflex": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    ".next",
    "next.config.ts",
    "lib/server/utilities/worker-bootstrap.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev -p 3211",
    "start": "next start -p 3211",
    "build": "next build && pnpm run build:cli",
    "build:cli": "tsc -p tsconfig.cli.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.cli.json --noEmit",
    "prepack": "node -e \"require('fs').rmSync('.next/cache', { recursive: true, force: true })\"",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.133.0",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-tabs": "^1",
    "@tailwindcss/node": "^4.3.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "chokidar": "^4",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "commander": "^14",
    "esbuild": "^0.28.0",
    "execa": "^9",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ignore": "^7",
    "lucide-react": "^0.475",
    "mermaid": "^11.15.0",
    "next": "^15",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^1",
    "tailwind-merge": "^2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^6"
  }
}
